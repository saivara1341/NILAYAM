# ============================================================
# Nilayam Platform — Environment Template
# Make a copy of this file and name it .env.local for development
# ============================================================

# ── Application Configuration ────────────────────────────────
NODE_ENV=development
PORT=3001
VITE_API_BASE_URL=http://localhost:3001/api

# ── Supabase Configuration (Required) ────────────────────────
# Get these from Supabase Dashboard -> Settings -> API
VITE_SUPABASE_URL=YOUR_SUPABASE_URL_HERE
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# Database Connection (Backend + Migrations)
SUPABASE_DB_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
DB_PASSWORD=YOUR_DB_PASSWORD_HERE

# ── Authentication Secrets ───────────────────────────────────
# Must be at least 32 characters long
JWT_SECRET=generate_a_strong_random_secret_here

# ── Razorpay Integration (Payments) ──────────────────────────
# Get these from Razorpay Dashboard -> Settings -> API Keys
# Frontend uses the public key. Backend uses the key id + secret.
VITE_RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_KEY_SECRET
# Point this to your backend root or /api base. Both are supported by the frontend checkout helper.
VITE_API_BASE_URL=http://localhost:8080

# ── AI Integration (Gemini) ──────────────────────────────────
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
VITE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# ── Logistics Integration (Delhivery) ────────────────────────
DELHIVERY_TOKEN=YOUR_DELHIVERY_TOKEN

# ── SMTP Configuration (Emails) ──────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=no-reply@nilayam.in
SMTP_PASS=YOUR_APP_PASSWORD

# ── Frontend Specific ────────────────────────────────────────
# Force Vite to use a specific port
VITE_PORT=5172
